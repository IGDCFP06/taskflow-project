{
  "info": {
    "name": "TaskFlow API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/health"
      }
    },
    {
      "name": "Get Tasks",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tasks"
      }
    },
    {
      "name": "Create Task",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Practicar middleware\",\n  \"category\": \"Estudio\",\n  \"priority\": \"Media\",\n  \"dueDate\": null\n}"
        },
        "url": "{{baseUrl}}/api/v1/tasks"
      }
    },
    {
      "name": "Create Task 400",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"ab\",\n  \"category\": \"Estudio\",\n  \"priority\": \"Alta\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/tasks"
      }
    },
    {
      "name": "Delete Task 404",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/v1/tasks/no-existe"
      }
    },
    {
      "name": "Debug 500",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/debug/error"
      }
    }
  ]
}
